# ================================
# SERVER CONFIGURATION
# ================================
PORT=3000
NODE_ENV=development

# ================================
# DATABASE CONFIGURATION (PostgreSQL)
# ================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=warung_rebahan_shop

# ================================
# WARUNG REBAHAN API
# ================================
# Get your API key from: https://warungrebahan.com/dashboard
WR_API_URL=https://warungrebahan.com/api/v1
WR_API_KEY=DHgq4Kzc35K3obiEUPIpiGLOkgLuFHIb

# ================================
# SECURITY
# ================================
# Generate strong random strings for production!
# You can use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here_change_in_production
SESSION_SECRET=your_session_secret_here_change_in_production

# ================================
# BUSINESS CONFIGURATION
# ================================
# Markup Configuration - Adjust your profit margin
# Formula: our_price = original_price + (original_price * MARKUP_PERCENTAGE / 100) + FIXED_MARKUP

# Percentage markup (%)
MARKUP_PERCENTAGE=20

# Fixed markup per transaction (IDR)
FIXED_MARKUP=5000

# Example:
# Original Price: Rp 100,000
# Our Price: Rp 100,000 + (Rp 100,000 * 20 / 100) + Rp 5,000
# Our Price: Rp 100,000 + Rp 20,000 + Rp 5,000 = Rp 125,000
# Profit: Rp 25,000 per transaction
